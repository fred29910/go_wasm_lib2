// Custom TypeScript Template Example
// This template demonstrates how to customize the TypeScript SDK generation output.
// Usage: gowasm-generator generate -s openapi.yaml -o ./output --ts-template ./custom.ts.tmpl
//
// Available template variables:
//   - .Doc           : Parsed OpenAPI document
//   - .Config        : Generator configuration (ModuleName, Package, RuntimeImport, etc.)
//   - .InfoTitle     : API title from OpenAPI info
//   - .InfoVersion   : API version from OpenAPI info
//   - .BaseURL       : Default server URL
//   - .Schemas       : All schema definitions
//   - .Operations    : All operation definitions
//   - .OperationIDs  : Sorted list of operation IDs

// ============================================================================
// API: {{.InfoTitle}} v{{.InfoVersion}}
// Base URL: {{.BaseURL}}
// ============================================================================

// Core Types
export interface WASMError {
	code: string;
	message: string;
	details?: string;
}

export interface HTTPResponse {
	status: number;
	headers: Record<string, string>;
	body: any;
	error?: WASMError;
}

export interface HTTPRequest {
	method: string;
	path: string;
	pathParams?: Record<string, string>;
	headers?: Record<string, string>;
	query?: Record<string, string>;
	body?: any;
}

// ============================================================================
// Schema Types
// ============================================================================

{{range .Schemas}}
// {{.GoName}} - {{.Name}} resource
export interface {{.GoName}} {
{{range .Properties}}	// {{.Name}}{{if .Required}} (required){{end}}{{if .Format}} - format: {{.Format}}{{end}}
	{{.TSName}}{{if not .Required}}?{{end}}: {{.TSType}};
{{end}}}

{{end}}

// ============================================================================
// Operation Request Types
// ============================================================================

{{range .Operations}}
// {{.RequestInterface}} - Parameters for {{.ID}} operation
export interface {{.RequestInterface}} {
{{range .PathParams}}	// {{.Name}} - path parameter{{if .Required}} (required){{end}}
	{{.TSName}}{{if not .Required}}?{{end}}: {{.TSType}};
{{end}}{{range .QueryParams}}	// {{.Name}} - query parameter{{if .Required}} (required){{end}}
	{{.TSName}}{{if not .Required}}?{{end}}: {{.TSType}};
{{end}}	// Path params override
	pathParams?: Record<string, string>;
	// Custom query parameters
	query?: Record<string, string>;
	// Custom request headers
	headers?: Record<string, string>;
{{if .HasBody}}	// Request body
	body?: {{.BodyType}};
{{end}}}

{{end}}

// ============================================================================
// Operation Response Types
// ============================================================================

{{range .Operations}}
{{$op := .}}
{{range .Responses}}
{{if .Primary}}
// {{.StructName}} - Response from {{.ID}} operation
export interface {{$op.ResponseInterface}} {
	data?: {{.TSType}};
}
{{else}}
// {{$op.RequestInterface}}{{.Code}}Response - Alternative response from {{.ID}} operation
export interface {{$op.RequestInterface}}{{.Code}}Response {
	data?: {{.TSType}};
}
{{end}}
{{end}}
{{end}}

// ============================================================================
// WASM Configuration
// ============================================================================

export interface WASMConfig {
	baseUrl: string;
	timeout?: number;
	headers?: Record<string, string>;
	credentials?: RequestCredentials;
}

export interface WASMReady {
	wasmReady: boolean;
}

declare global {
	interface Window {
		wasmReady?: boolean;
		wasmInitClient?: (config: WASMConfig) => Promise<any>;
		wasmCallAPI?: (operationId: string, request: HTTPRequest) => Promise<HTTPResponse>;
		wasmSetAuthToken?: (token: string, scheme?: string) => any;
		wasmClearAuthToken?: () => any;
		wasmGetConfig?: () => any;
	}
}

// ============================================================================
// WASM SDK Class
// ============================================================================

export class WASMSDK {
	private wasmUrl: string;
	private initialized: boolean = false;

	constructor(wasmUrl?: string) {
		this.wasmUrl = wasmUrl || './main.wasm';
	}

	async load(): Promise<void> {
		if (typeof window === 'undefined') {
			throw new Error('WASM SDK can only be used in browser environment');
		}

		const response = await fetch(this.wasmUrl);
		const bytes = await response.arrayBuffer();
		const wasmModule = await WebAssembly.instantiate(bytes, {
			env: {
				// Go WASM imports
			}
		});

		// Make exports available
		const { instance } = wasmModule;
		if (instance && instance.exports) {
			for (const [key, value] of Object.entries(instance.exports)) {
				(window as any)[key] = value;
			}
		}
	}

	async init(config: WASMConfig): Promise<void> {
		if (typeof window.wasmInitClient !== 'function') {
			throw new Error('WASM module not loaded. Call load() first.');
		}
		await window.wasmInitClient(config);
		this.initialized = true;
	}

	isInitialized(): boolean {
		return this.initialized;
	}

	setAuthToken(token: string, scheme: string = 'Bearer'): void {
		if (typeof window.wasmSetAuthToken !== 'function') {
			throw new Error('WASM module not loaded. Call load() first.');
		}
		window.wasmSetAuthToken(token, scheme);
	}

	clearAuthToken(): void {
		if (typeof window.wasmClearAuthToken !== 'function') {
			throw new Error('WASM module not loaded. Call load() first.');
		}
		window.wasmClearAuthToken();
	}

	async getConfig(): Promise<WASMConfig | null> {
		if (typeof window.wasmGetConfig !== 'function') {
			throw new Error('WASM module not loaded. Call load() first.');
		}
		const result = window.wasmGetConfig();
		return result.success ? result.config : null;
	}

	async callAPI(operationId: string, request: HTTPRequest): Promise<HTTPResponse> {
		if (typeof window.wasmCallAPI !== 'function') {
			throw new Error('WASM module not loaded. Call load() first.');
		}
		return window.wasmCallAPI(operationId, request);
	}
}

// ============================================================================
// Typed API Functions
// ============================================================================

{{range .Operations}}
// {{.ID}} - {{.Method}} {{.Path}}
// {{.Summary}}
export async function {{.TSName}}(params: {{.RequestInterface}}): Promise<HTTPResponse> {
	const request: HTTPRequest = {
		method: '{{.Method}}',
		path: '{{.Path}}',
		headers: params.headers || {},
		query: params.query || {},
{{if .PathParams}}
		pathParams: {
{{range .PathParams}}			'{{.Name}}': String(params.{{.TSName}}),
{{end}}		},
{{end}}
{{if .HasBody}}		body: params.body,
{{end}}	};
	return (window as any).wasmCallAPI('{{.ID}}', request);
}

{{end}}
