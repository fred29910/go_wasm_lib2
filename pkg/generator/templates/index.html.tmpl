<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{htmlEscape .InfoTitle}} - Debug Console</title>
	<script src="https://cdn.tailwindcss.com"></script>
	<script>
		tailwind.config = {
			theme: {
				extend: {
					colors: {
						method: {
							get: '#10b981',
							post: '#3b82f6',
							put: '#f59e0b',
							delete: '#ef4444',
							patch: '#8b5cf6'
						}
					}
				}
			}
		}
	</script>
	<style>
		.method-get { background-color: #10b981; }
		.method-post { background-color: #3b82f6; }
		.method-put { background-color: #f59e0b; }
		.method-delete { background-color: #ef4444; }
		.method-patch { background-color: #8b5cf6; }
		.status-2xx { color: #10b981; }
		.status-3xx { color: #f59e0b; }
		.status-4xx { color: #f59e0b; }
		.status-5xx { color: #ef4444; }
		.log-row:hover { background-color: #f9fafb; }
		.log-details { display: none; }
		.log-details.open { display: table-row; }
		pre { white-space: pre-wrap; word-break: break-all; }
	</style>
</head>
<body class="bg-gray-100 min-h-screen">
	<!-- Status Bar -->
	<div id="statusBar" class="bg-gray-900 text-white px-4 py-2 flex items-center justify-between text-sm">
		<div class="flex items-center gap-6">
			<span class="font-semibold">{{htmlEscape .InfoTitle}} v{{htmlEscape .InfoVersion}}</span>
			<div class="flex items-center gap-2">
				<span class="text-gray-400">WASM:</span>
				<span id="wasmStatus" class="inline-flex items-center gap-1">
					<span class="w-2 h-2 rounded-full bg-gray-500"></span>
					<span>Not Loaded</span>
				</span>
			</div>
			<div class="flex items-center gap-2">
				<span class="text-gray-400">Client:</span>
				<span id="clientStatus" class="inline-flex items-center gap-1">
					<span class="w-2 h-2 rounded-full bg-gray-500"></span>
					<span>Not Initialized</span>
				</span>
			</div>
		</div>
		<div class="flex items-center gap-4">
			<span id="baseUrlDisplay" class="text-gray-400 text-xs">{{htmlEscape .BaseURL}}</span>
			<button id="getConfigBtn" class="bg-gray-700 hover:bg-gray-600 px-3 py-1 rounded text-xs">Get Config</button>
		</div>
	</div>

	<div class="max-w-7xl mx-auto p-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
		<!-- Left Column: Config + Auth -->
		<div class="lg:col-span-1 space-y-4">
			<!-- Configuration Panel -->
			<div class="bg-white rounded-lg shadow">
				<div class="px-4 py-3 border-b">
					<h2 class="text-lg font-semibold">Configuration</h2>
				</div>
				<div class="p-4 space-y-3">
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Base URL</label>
						<input type="text" id="cfgBaseUrl" value="{{htmlEscape .BaseURL}}" class="w-full px-3 py-2 border rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
					</div>
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Timeout (seconds)</label>
						<input type="number" id="cfgTimeout" value="30" min="1" max="300" class="w-full px-3 py-2 border rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
					</div>
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Credentials</label>
						<select id="cfgCredentials" class="w-full px-3 py-2 border rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
							<option value="same-origin">same-origin</option>
							<option value="include">include</option>
							<option value="omit">omit</option>
						</select>
					</div>
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Custom Headers (JSON)</label>
						<textarea id="cfgHeaders" rows="3" placeholder='{"X-Custom-Header": "value"}' class="w-full px-3 py-2 border rounded text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
					</div>
					<div class="flex gap-2 pt-2">
						<button id="loadBtn" class="flex-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded text-sm font-medium">Load WASM</button>
						<button id="initBtn" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium">Init Client</button>
					</div>
				</div>
			</div>

			<!-- Auth Panel -->
			<div class="bg-white rounded-lg shadow">
				<div class="px-4 py-3 border-b">
					<h2 class="text-lg font-semibold">Authentication</h2>
				</div>
				<div class="p-4 space-y-3">
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Auth Token</label>
						<input type="text" id="authToken" placeholder="Enter JWT or API token" class="w-full px-3 py-2 border rounded text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
					</div>
					<div>
						<label class="block text-sm font-medium text-gray-700 mb-1">Scheme</label>
						<select id="authScheme" class="w-full px-3 py-2 border rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
							<option value="Bearer">Bearer</option>
							<option value="Basic">Basic</option>
							<option value="Token">Token</option>
						</select>
					</div>
					<div class="flex gap-2 pt-2">
						<button id="setAuthBtn" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm font-medium">Set Auth</button>
						<button id="clearAuthBtn" class="flex-1 bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded text-sm font-medium">Clear Auth</button>
					</div>
				</div>
			</div>

			<!-- Request Log -->
			<div class="bg-white rounded-lg shadow">
				<div class="px-4 py-3 border-b flex items-center justify-between">
					<h2 class="text-lg font-semibold">Request Log</h2>
					<button id="clearLogBtn" class="text-xs text-gray-500 hover:text-gray-700">Clear</button>
				</div>
				<div class="overflow-x-auto">
					<table class="w-full text-sm">
						<thead class="bg-gray-50">
							<tr>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">#</th>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Time</th>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Operation</th>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Method</th>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
								<th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Duration</th>
							</tr>
						</thead>
						<tbody id="logTableBody" class="divide-y divide-gray-200">
							<tr id="logEmpty">
								<td colspan="6" class="px-3 py-8 text-center text-gray-400 text-sm">No requests yet</td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<!-- Right Column: Operations -->
		<div class="lg:col-span-2 space-y-4">
			<div class="bg-white rounded-lg shadow">
				<div class="px-4 py-3 border-b">
					<h2 class="text-lg font-semibold">API Operations</h2>
					<p class="text-xs text-gray-500 mt-1">Click an operation card to expand parameters, then execute</p>
				</div>
				<div id="operations" class="p-4 space-y-4">
{{range .Operations}}
					<div class="border rounded-lg overflow-hidden" data-operation-id="{{.ID}}">
						<div class="operation-header px-4 py-3 bg-gray-50 cursor-pointer flex items-center justify-between" onclick="DebugConsole.toggleOperation('{{.ID}}')">
							<div class="flex items-center gap-3">
								<span class="method-{{toLower .Method}} text-white text-xs font-bold px-2 py-1 rounded uppercase">{{.Method}}</span>
								<div>
									<span class="font-medium text-sm">{{htmlEscape .Summary}}</span>
									<span class="text-gray-500 text-xs ml-2 font-mono">{{htmlEscape .Path}}</span>
								</div>
							</div>
							<span class="text-gray-400 text-xs" id="chevron-{{.ID}}">&#9660;</span>
						</div>
						<div class="operation-body hidden px-4 py-4 border-t bg-white" id="body-{{.ID}}">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
{{if or .PathParams .QueryParams}}
								<div class="space-y-3">
									<h4 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Parameters</h4>
{{range .PathParams}}
									<div class="param-field">
										<label class="block text-xs font-medium text-gray-600 mb-1">
											{{htmlEscape .Name}}
											{{if .Required}}<span class="text-red-500">*</span>{{end}}
											<span class="text-gray-400">(path)</span>
										</label>
										<input type="text"
											data-param-name="{{htmlEscape .Name}}"
											data-param-type="path"
											data-param-required="{{.Required}}"
											data-ts-type="{{.TSType}}"
											placeholder="{{htmlEscape .Name}}"
											class="param-input w-full px-3 py-2 border rounded text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
									</div>
{{end}}
{{range .QueryParams}}
									<div class="param-field">
										<label class="block text-xs font-medium text-gray-600 mb-1">
											{{htmlEscape .Name}}
											{{if .Required}}<span class="text-red-500">*</span>{{end}}
											<span class="text-gray-400">(query)</span>
										</label>
{{if .EnumValues}}
										<select data-param-name="{{htmlEscape .Name}}"
											data-param-type="query"
											data-param-required="{{.Required}}"
											data-ts-type="{{.TSType}}"
											class="param-input w-full px-3 py-2 border rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
											<option value="">-- select {{htmlEscape .Name}} --</option>
{{range .EnumValues}}
											<option value="{{htmlEscape .}}">{{htmlEscape .}}</option>
{{end}}
										</select>
{{else}}
										<input type="text"
											data-param-name="{{htmlEscape .Name}}"
											data-param-type="query"
											data-param-required="{{.Required}}"
											data-ts-type="{{.TSType}}"
											placeholder="{{htmlEscape .Name}}"
											class="param-input w-full px-3 py-2 border rounded text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
{{end}}
									</div>
{{end}}
								</div>
{{end}}
{{if .HasBody}}
								<div class="space-y-3">
									<h4 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Request Body</h4>
									<div>
										<label class="block text-xs font-medium text-gray-600 mb-1">Content Type: {{htmlEscape .BodyType}}</label>
										<textarea data-param-name="__body__"
											data-param-type="body"
											rows="8"
											placeholder='{"key": "value"}'
											class="param-input w-full px-3 py-2 border rounded text-sm font-mono focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
									</div>
								</div>
{{end}}
{{if not (or .PathParams .QueryParams .HasBody)}}
								<div class="md:col-span-2 text-sm text-gray-400 italic">No parameters required</div>
{{end}}
							</div>
							<div class="mt-4 flex items-center gap-3">
								<button onclick="DebugConsole.callAPI('{{.ID}}')" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded text-sm font-medium">Execute</button>
								<span class="text-xs text-gray-400" id="result-{{.ID}}"></span>
							</div>
							<div class="mt-4 hidden" id="response-{{.ID}}">
								<h4 class="text-sm font-semibold text-gray-700 mb-2">Response</h4>
								<div class="bg-gray-900 text-gray-100 rounded p-3 text-xs font-mono overflow-x-auto">
									<pre id="responseBody-{{.ID}}"></pre>
								</div>
							</div>
						</div>
					</div>
{{end}}
{{if not .Operations}}
					<div class="text-center py-12 text-gray-400 text-sm">No operations defined</div>
{{end}}
				</div>
			</div>
		</div>
	</div>

	<script>
		(function() {
			'use strict';

			var DebugConsole = (function() {
				var state = {
					wasmLoaded: false,
					clientInitialized: false,
					baseUrl: '',
					timeout: 30,
					headers: {},
					authToken: null,
					authScheme: 'Bearer',
					logEntries: [],
					logCounter: 0
				};

				var methodColors = {
					'GET': 'status-2xx',
					'POST': 'status-3xx',
					'PUT': 'status-4xx',
					'DELETE': 'status-5xx',
					'PATCH': 'status-5xx'
				};

				function escapeHtml(str) {
					if (typeof str !== 'string') return str;
					return str
						.replace(/&/g, '&amp;')
						.replace(/</g, '&lt;')
						.replace(/>/g, '&gt;')
						.replace(/"/g, '&quot;')
						.replace(/'/g, '&#039;');
				}

				function formatJson(obj) {
					try {
						return JSON.stringify(obj, null, 2);
					} catch (e) {
						return String(obj);
					}
				}

				function updateStatus() {
					var wasmEl = document.getElementById('wasmStatus');
					var clientEl = document.getElementById('clientStatus');
					var urlEl = document.getElementById('baseUrlDisplay');

					if (wasmEl) {
						if (state.wasmLoaded) {
							wasmEl.innerHTML = '<span class="w-2 h-2 rounded-full bg-green-400"></span><span>Loaded</span>';
						} else {
							wasmEl.innerHTML = '<span class="w-2 h-2 rounded-full bg-gray-500"></span><span>Not Loaded</span>';
						}
					}
					if (clientEl) {
						if (state.clientInitialized) {
							clientEl.innerHTML = '<span class="w-2 h-2 rounded-full bg-green-400"></span><span>Ready</span>';
						} else {
							clientEl.innerHTML = '<span class="w-2 h-2 rounded-full bg-gray-500"></span><span>Not Initialized</span>';
						}
					}
					if (urlEl && state.baseUrl) {
						urlEl.textContent = state.baseUrl;
					}
				}

				// Load the Go wasm_exec.js helper dynamically
				function ensureWasmExec() {
					return new Promise(function(resolve, reject) {
						if (typeof Go !== 'undefined') {
							resolve();
							return;
						}
						var script = document.createElement('script');
						script.src = 'wasm_exec.js';
						script.onload = resolve;
						script.onerror = function() {
							reject(new Error(
								'wasm_exec.js not found. Copy it from $(go env GOROOT)/misc/wasm/wasm_exec.js ' +
								'and place it alongside this HTML file.'
							));
						};
						document.head.appendChild(script);
					});
				}

				// Load WASM binary: fetch main.wasm and instantiate with Go runtime
				function load() {
					return new Promise(function(resolve, reject) {
						if (state.wasmLoaded) {
							resolve();
							return;
						}
						ensureWasmExec().then(function() {
							var go = new Go();
							fetch('main.wasm')
								.then(function(resp) { return resp.arrayBuffer(); })
								.then(function(bytes) { return WebAssembly.instantiate(bytes, go.importObject); })
								.then(function(result) {
									go.run(result.instance);
									// After go.run(), Go's ExportMain() has set wasmInitClient etc.
									if (typeof window.wasmInitClient !== 'function') {
										reject(new Error(
											'WASM loaded but wasmInitClient not found. ' +
											'Ensure the WASM binary was built with the gowasm runtime.'
										));
										return;
									}
									state.wasmLoaded = true;
									updateStatus();
									resolve();
								})
								.catch(function(err) {
									reject(new Error('Failed to instantiate WASM: ' + err.message));
								});
						}).catch(function(err) {
							reject(err);
						});
					});
				}

				// Initialize the HTTP client via wasmInitClient (requires WASM loaded first)
				function init() {
					return new Promise(function(resolve, reject) {
						if (state.clientInitialized) {
							resolve();
							return;
						}
						if (!state.wasmLoaded) {
							reject(new Error('WASM not loaded. Click "Load WASM" first.'));
							return;
						}
						try {
							var config = {
								baseUrl: document.getElementById('cfgBaseUrl').value,
								timeout: parseInt(document.getElementById('cfgTimeout').value, 10) || 30,
								credentials: document.getElementById('cfgCredentials').value
							};
							var headersText = document.getElementById('cfgHeaders').value.trim();
							if (headersText) {
								try {
									config.headers = JSON.parse(headersText);
								} catch (e) {
									console.warn('Invalid headers JSON, ignoring');
								}
							}
							state.baseUrl = config.baseUrl;
							state.timeout = config.timeout;
							state.headers = config.headers || {};
							var result = window.wasmInitClient(config);
							if (result && result.then) {
								result.then(function() {
									state.clientInitialized = true;
									updateStatus();
									resolve();
								}).catch(function(err) {
									reject(err);
								});
							} else {
								state.clientInitialized = true;
								updateStatus();
								resolve();
							}
						} catch (e) {
							reject(e);
						}
					});
				}

				function collectParams(operationId) {
					var params = {};
					var bodyEl = document.querySelector('#body-' + operationId + ' [data-param-type="body"]');
					if (bodyEl && bodyEl.value.trim()) {
						try {
							params.body = JSON.parse(bodyEl.value);
						} catch (e) {
							params.body = bodyEl.value;
						}
					}
					var pathParams = {};
					var queryParams = {};
					var inputs = document.querySelectorAll('#body-' + operationId + ' .param-input');
					inputs.forEach(function(input) {
						var name = input.getAttribute('data-param-name');
						var type = input.getAttribute('data-param-type');
						var value = input.value.trim();
						if (!value) return;
						if (type === 'path') {
							pathParams[name] = value;
						} else if (type === 'query') {
							queryParams[name] = value;
						}
					});
					return { pathParams: pathParams, query: queryParams, body: params.body };
				}

				function callAPI(operationId) {
					var startTime = Date.now();
					var operation = findOperation(operationId);
					if (!operation) {
						console.error('Operation not found:', operationId);
						return;
					}
					var collected = collectParams(operationId);
					var request = {
						method: operation.Method,
						path: operation.Path,
						pathParams: Object.keys(collected.pathParams).length > 0 ? collected.pathParams : undefined,
						query: Object.keys(collected.query).length > 0 ? collected.query : undefined,
						body: collected.body
					};
					var resultEl = document.getElementById('result-' + operationId);
					var responseEl = document.getElementById('response-' + operationId);
					var bodyEl = document.getElementById('responseBody-' + operationId);
					if (resultEl) resultEl.textContent = 'Calling...';
					if (responseEl) responseEl.classList.add('hidden');

					function handleResponse(response) {
						var duration = Date.now() - startTime;
						var status = response.status || 0;
						var statusClass = 'status-2xx';
						if (status >= 500) statusClass = 'status-5xx';
						else if (status >= 400) statusClass = 'status-4xx';
						else if (status >= 300) statusClass = 'status-3xx';
						if (resultEl) {
							resultEl.innerHTML = '<span class="' + statusClass + ' font-semibold">' + status + '</span> in ' + duration + 'ms';
						}
						if (bodyEl) {
							bodyEl.textContent = formatJson(response);
						}
						if (responseEl) {
							responseEl.classList.remove('hidden');
						}
						appendLog({
							id: ++state.logCounter,
							timestamp: new Date().toLocaleTimeString(),
							operationId: operationId,
							summary: operation.Summary,
							method: operation.Method,
							status: status,
							duration: duration,
							request: request,
							response: response
						});
					}

					function handleError(error) {
						var duration = Date.now() - startTime;
						var status = 0;
						var errorBody = { error: { code: 'UNKNOWN', message: String(error) } };
						if (error && typeof error === 'object') {
							status = error.code || 0;
							errorBody = error;
						}
						if (resultEl) {
							resultEl.innerHTML = '<span class="text-red-600 font-semibold">Error</span> in ' + duration + 'ms';
						}
						if (bodyEl) {
							bodyEl.textContent = formatJson(errorBody);
						}
						if (responseEl) {
							responseEl.classList.remove('hidden');
						}
						appendLog({
							id: ++state.logCounter,
							timestamp: new Date().toLocaleTimeString(),
							operationId: operationId,
							summary: operation.Summary,
							method: operation.Method,
							status: status,
							duration: duration,
							request: request,
							response: errorBody,
							error: true
						});
					}

					try {
						var result = window.wasmCallAPI(operationId, request);
						if (result && result.then) {
							result.then(handleResponse).catch(handleError);
						} else {
							handleResponse(result || {});
						}
					} catch (e) {
						handleError(e);
					}
				}

				function findOperation(id) {
					var ops = window.__debugConsoleOperations || [];
					for (var i = 0; i < ops.length; i++) {
						if (ops[i].ID === id) return ops[i];
					}
					return null;
				}

				function setAuth() {
					var token = document.getElementById('authToken').value.trim();
					var scheme = document.getElementById('authScheme').value;
					if (!token) {
						alert('Please enter an auth token');
						return;
					}
					state.authToken = token;
					state.authScheme = scheme;
					try {
						window.wasmSetAuthToken(token, scheme);
					} catch (e) {
						console.warn('wasmSetAuthToken not available:', e);
					}
				}

				function clearAuth() {
					state.authToken = null;
					state.authScheme = 'Bearer';
					document.getElementById('authToken').value = '';
					try {
						window.wasmClearAuthToken();
					} catch (e) {
						console.warn('wasmClearAuthToken not available:', e);
					}
				}

				function getConfig() {
					try {
						var config = window.wasmGetConfig();
						if (config) {
							alert('Current Config:\n\n' + formatJson(config));
						} else {
							alert('No config available (client not initialized)');
						}
					} catch (e) {
						alert('Error getting config: ' + e.message);
					}
				}

				function toggleOperation(operationId) {
					var body = document.getElementById('body-' + operationId);
					var chevron = document.getElementById('chevron-' + operationId);
					if (body && chevron) {
						var isHidden = body.classList.contains('hidden');
						if (isHidden) {
							body.classList.remove('hidden');
							chevron.innerHTML = '&#9650;';
						} else {
							body.classList.add('hidden');
							chevron.innerHTML = '&#9660;';
						}
					}
				}

				function appendLog(entry) {
					state.logEntries.unshift(entry);
					var tbody = document.getElementById('logTableBody');
					var emptyRow = document.getElementById('logEmpty');
					if (emptyRow) emptyRow.remove();

					var statusClass = 'status-2xx';
					if (entry.status >= 500) statusClass = 'status-5xx';
					else if (entry.status >= 400) statusClass = 'status-4xx';
					else if (entry.status >= 300) statusClass = 'status-3xx';

					var methodClass = 'method-' + entry.method.toLowerCase();

					var tr = document.createElement('tr');
					tr.className = 'log-row cursor-pointer border-b';
					tr.setAttribute('data-log-id', entry.id);
					tr.onclick = function() { toggleLogDetail(entry.id); };

					var statusDisplay = entry.status > 0 ? entry.status : 'ERR';
					var durationDisplay = entry.duration + 'ms';

					tr.innerHTML =
						'<td class="px-3 py-2 text-gray-500">' + entry.id + '</td>' +
						'<td class="px-3 py-2 text-gray-500 text-xs">' + escapeHtml(entry.timestamp) + '</td>' +
						'<td class="px-3 py-2">' +
							'<span class="font-medium text-xs">' + escapeHtml(entry.operationId) + '</span>' +
							'<div class="text-xs text-gray-400">' + escapeHtml(entry.summary) + '</div>' +
						'</td>' +
						'<td class="px-3 py-2"><span class="' + methodClass + ' text-white text-xs font-bold px-2 py-0.5 rounded uppercase">' + escapeHtml(entry.method) + '</span></td>' +
						'<td class="px-3 py-2 ' + statusClass + ' font-semibold">' + escapeHtml(statusDisplay) + '</td>' +
						'<td class="px-3 py-2 text-gray-600">' + escapeHtml(durationDisplay) + '</td>';

					tbody.insertBefore(tr, tbody.firstChild);

					var detailTr = document.createElement('tr');
					detailTr.className = 'log-details';
					detailTr.setAttribute('data-log-detail', entry.id);
					detailTr.innerHTML =
						'<td colspan="6" class="px-3 py-3 bg-gray-50">' +
							'<div class="grid grid-cols-1 md:grid-cols-2 gap-3">' +
								'<div>' +
									'<h5 class="text-xs font-semibold text-gray-500 uppercase mb-1">Request</h5>' +
									'<pre class="bg-white p-2 rounded border text-xs font-mono overflow-x-auto">' + escapeHtml(formatJson(entry.request)) + '</pre>' +
								'</div>' +
								'<div>' +
									'<h5 class="text-xs font-semibold text-gray-500 uppercase mb-1">Response</h5>' +
									'<pre class="bg-white p-2 rounded border text-xs font-mono overflow-x-auto">' + escapeHtml(formatJson(entry.response)) + '</pre>' +
								'</div>' +
							'</div>' +
						'</td>';

					tbody.insertBefore(detailTr, tbody.firstChild);
				}

				function toggleLogDetail(logId) {
					var detail = document.querySelector('[data-log-detail="' + logId + '"]');
					if (detail) {
						detail.classList.toggle('open');
					}
				}

				function clearLog() {
					state.logEntries = [];
					state.logCounter = 0;
					var tbody = document.getElementById('logTableBody');
					tbody.innerHTML = '<tr id="logEmpty"><td colspan="6" class="px-3 py-8 text-center text-gray-400 text-sm">No requests yet</td></tr>';
				}

				function initWindowOperations() {
					try {
						var opsData = window.__debugConsoleOperations;
						if (opsData && Array.isArray(opsData)) {
							state.operations = opsData;
						}
					} catch (e) {
						console.warn('Could not load operations from window.__debugConsoleOperations');
					}
				}

				function bootstrap() {
					initWindowOperations();
					updateStatus();

					document.getElementById('loadBtn').addEventListener('click', function() {
						load().then(function() {
							console.log('WASM loaded successfully');
							alert('WASM loaded. Now click "Init Client" to configure.');
						}).catch(function(err) {
							console.error('Failed to load WASM:', err);
							alert('Failed to load WASM: ' + err.message);
						});
					});

					document.getElementById('initBtn').addEventListener('click', function() {
						init().then(function() {
							console.log('Client initialized');
						}).catch(function(err) {
							console.error('Failed to init client:', err);
							alert('Failed to initialize client: ' + err.message);
						});
					});

					document.getElementById('setAuthBtn').addEventListener('click', setAuth);
					document.getElementById('clearAuthBtn').addEventListener('click', clearAuth);
					document.getElementById('getConfigBtn').addEventListener('click', getConfig);
					document.getElementById('clearLogBtn').addEventListener('click', clearLog);
				}

				return {
					bootstrap: bootstrap,
					load: load,
					init: init,
					callAPI: callAPI,
					setAuth: setAuth,
					clearAuth: clearAuth,
					getConfig: getConfig,
					toggleOperation: toggleOperation,
					appendLog: appendLog,
					updateStatus: updateStatus,
					clearLog: clearLog
				};
			})();

			window.DebugConsole = DebugConsole;

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', DebugConsole.bootstrap);
			} else {
				DebugConsole.bootstrap();
			}
		})();
	</script>

	<script>
		window.__debugConsoleOperations = [
{{range .Operations}}
			{
				ID: '{{.ID}}',
				Method: '{{.Method}}',
				Path: '{{.Path}}',
				Summary: '{{.Summary}}',
				PathParams: {{if .PathParams}}[{{range $i, $p := .PathParams}}{{if $i}},{{end}}{ Name: '{{$p.Name}}', TSName: '{{$p.TSName}}', TSType: '{{$p.TSType}}', Required: {{$p.Required}} }{{end}}]{{else}}[]{{end}},
				QueryParams: {{if .QueryParams}}[{{range $i, $p := .QueryParams}}{{if $i}},{{end}}{ Name: '{{$p.Name}}', TSName: '{{$p.TSName}}', TSType: '{{$p.TSType}}', Required: {{$p.Required}} }{{end}}]{{else}}[]{{end}},
				HasBody: {{.HasBody}},
				BodyType: '{{.BodyType}}'
			},
{{end}}
		];
	</script>
</body>
</html>
